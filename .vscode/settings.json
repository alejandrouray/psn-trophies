{
  "workbench.colorCustomizations": {
    "activityBar.activeBackground": "#feffff",
    "activityBar.background": "#feffff",
    "activityBar.foreground": "#15202b",
    "activityBar.inactiveForeground": "#15202b99",
    "activityBarBadge.background": "#ff80ff",
    "activityBarBadge.foreground": "#15202b",
    "commandCenter.border": "#15202b99",
    "sash.hoverBorder": "#feffff",
    "statusBar.background": "#cbf3ff",
    "statusBar.foreground": "#15202b",
    "statusBarItem.hoverBackground": "#98e7ff",
    "statusBarItem.remoteBackground": "#cbf3ff",
    "statusBarItem.remoteForeground": "#15202b",
    "titleBar.activeBackground": "#cbf3ff",
    "titleBar.activeForeground": "#15202b",
    "titleBar.inactiveBackground": "#cbf3ff99",
    "titleBar.inactiveForeground": "#15202b99"
  },
  "peacock.color": "#cbf3ff",
  "editor.defaultFormatter": "biomejs.biome",
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.biome": "always",
    "source.organizeImports.biome": "always"
  },
  "biome.enabled": true,
  "material-icon-theme.activeIconPack": "react",
  "material-icon-theme.folders.theme": "specific",
  "material-icon-theme.folders.color": "#6272a4",
  "material-icon-theme.opacity": 0.9,
  "notebook.defaultFormatter": "biomejs.biome",
  "[typescript]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[json]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "editor.suggest.showStatusBar": false,
  "peacock.affectDebuggingStatusBar": false,
  "peacock.affectStatusAndTitleBorders": false,
  "workbench.view.showQuietly": {
    "workbench.panel.output": false
  }
}
